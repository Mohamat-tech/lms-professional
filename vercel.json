{
  "buildCommand": "npm install",
  "env": {
    "VERCEL_ENV": "production"
  },
  "functions": {
    "backend/**/*.php": {
      "runtime": "php-8.2"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/api/$1"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "/frontend/$1",
      "permanent": false
    }
  ]
}
